{
  "name": "druckform-mcp",
  "version": "0.1.0",
  "description": "MCP adapter for druckform — HTTP upload/download + job lifecycle",
  "license": "MIT",
  "engines": { "node": ">=22" },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "druckform-mcp": "./dist/index.js"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "druckform": "workspace:*"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "fastify": "^5.1.0",
    "yauzl": "^3.1.3",
    "zod": "^3.25"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/yauzl": "^2.10.0",
    "druckform": "workspace:*",
    "typescript": "^5.6.0",
    "tsup": "^8.3.0",
    "vitest": "^2.1.0",
    "@vitest/coverage-v8": "^2.1.0"
  }
}
